<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings>
    <package>{MODEL_PACKAGE}</package>
    <entity class="{MODEL_PACKAGE}.Employee" name="Employee">
        <table name="ts_employees"/>
        <named-native-queries>
            <named-native-query>
                <name>Employee.selectAll</name>
                <query>SELECT * FROM ts_employees</query>
            </named-native-query>
            <named-native-query>
                <name>Employee.selectByName</name>
                <query>SELECT * FROM ts_employees WHERE name = ?</query>
            </named-native-query>
        </named-native-queries>
        <attributes>
            <id name="employeeId" type="java.lang.Integer">
                <generated-value strategy="AUTO"/>
                <column name="employee_id"></column>
            </id>
            <basic name="employeeName" type="java.lang.String">
                <column name="employee_name" length="100" nullable="false" insertable="true" updatable="true"/>
            </basic>
            <basic name="location" type="java.lang.String">
                <column name="location" length="128" nullable="false" insertable="true" updatable="true"/>
            </basic>
            <basic name="salary" type="java.lang.Double">
                <column name="salary" nullable="false" precision="10" scale="2" insertable="true" updatable="true"/>
            </basic>
            <basic name="status" type="java.lang.Enum" value="[ACTIVE, INACTIVE, BLOCKED]">
                <column name="status" nullable="false" updatable="true"/>
            </basic>
            <basic name="createdDate" type="java.sql.Timestamp">
                <column name="created_date" nullable="false" insertable="true" updatable="false"/>
            </basic>
            <basic name="updatedDate" type="java.sql.Timestamp">
                <column name="updated_date" nullable="true" insertable="true" updatable="true"/>
            </basic>
        </attributes>
    </entity>
    <entity class="{MODEL_PACKAGE}.Department" name="Department">
        <table name="ts_departments"/>
        <named-native-queries>
            <named-native-query>
                <name>Department.selectAll</name>
                <query>SELECT * FROM ts_departments</query>
            </named-native-query>
            <named-native-query>
                <name>Department.selectByName</name>
                <query>SELECT * FROM ts_departments WHERE name = ?</query>
            </named-native-query>
        </named-native-queries>
        <attributes>
            <id name="departmentId" type="java.lang.String">
                <column name="department_id" length="32"></column>
            </id>
            <basic name="departmentName" type="java.lang.String">
                <column name="department_name" length="100" nullable="false" insertable="true" updatable="false"/>
            </basic>
            <basic name="employeeCount" type="java.lang.Integer">
                <column name="location" precision="10" nullable="false" insertable="true" updatable="true"/>
            </basic>
            <basic name="createdDate" type="java.sql.Timestamp">
                <column name="created_date" nullable="false" insertable="true" updatable="false"/>
            </basic>
            <basic name="updatedDate" type="java.sql.Timestamp">
                <column name="updated_date" nullable="true" insertable="true" updatable="true"/>
            </basic>
        </attributes>
    </entity>
</entity-mappings>